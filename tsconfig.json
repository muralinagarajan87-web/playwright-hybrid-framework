{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "outDir": "./dist",
    "rootDir": "./",
    "paths": {
      "@api/*": ["./src/api/*"],
      "@web/*": ["./src/web/*"],
      "@shared/*": ["./src/shared/*"],
      "@data/*": ["./test-data/*"]
    },
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "tests/**/*", "test-data/**/*", "*.ts"],
  "exclude": ["node_modules", "dist", "playwright-report", "test-results"]
}
