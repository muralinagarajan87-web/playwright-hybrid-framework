# ── Copy this file to .env for local development ──────────────────────────────
# .env is gitignored. This file is committed and documents every variable the
# framework reads. All values shown are the defaults used when the variable is
# absent — override only what you need to change.

# ── API target ────────────────────────────────────────────────────────────────
# Base URL for the Restful-Booker API. Override to point at a local instance or
# a different environment (staging, QA, etc.).
API_BASE_URL=https://restful-booker.herokuapp.com

# ── Web target ────────────────────────────────────────────────────────────────
# Base URL for the SauceDemo web app.
WEB_BASE_URL=https://www.saucedemo.com

# ── CI guards ────────────────────────────────────────────────────────────────
# Set by GitHub Actions automatically — do not set this locally.
# Controls: retries (0 locally / 2 in CI), forbidOnly, worker count.
# CI=true

# Set to "true" in the API-only CI workflow to skip the global-setup browser
# launch (Chromium is not installed in the api-tests runner).
# SKIP_BROWSER_SETUP=true

# ── Notifications (optional) ──────────────────────────────────────────────────
# Slack incoming webhook URL. If absent, the notification step in CI is skipped.
# Create one at: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
